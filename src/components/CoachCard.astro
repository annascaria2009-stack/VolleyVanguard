---
interface Props {
  name: string;
  role: string;
  photo: string;
  photoPosition?: string;
}

const { name, role, photo, photoPosition } = Astro.props;
---

<article class="card">
  <img
    src={photo}
    alt={`${name} — ${role}`}
    class="photo"
    style={photoPosition ? `object-position: ${photoPosition}` : undefined}
    loading="lazy"
    decoding="async"
  />
  <div class="body">
    <h3 class="name">{name}</h3>
    <p class="role">{role}</p>
    <div class="bio">
      <slot />
    </div>
  </div>
</article>

<style>
  .card {
    background: #fff;
    border-radius: var(--radius);
    overflow: hidden;
    box-shadow: 0 8px 24px rgba(11, 31, 58, 0.07);
    display: flex;
    flex-direction: column;
  }

  .photo {
    aspect-ratio: 4 / 5;
    width: 100%;
    object-fit: cover;
    display: block;
  }

  .body {
    padding: 18px 18px 22px;
  }

  .name {
    font-size: 22px;
    color: var(--navy);
  }

  .role {
    color: var(--coral);
    text-transform: uppercase;
    font-size: 12px;
    font-weight: 800;
    letter-spacing: 1.5px;
    margin-top: 4px;
  }

  .bio {
    color: var(--muted);
    font-size: 15px;
    line-height: 1.6;
    margin-top: 12px;
  }
</style>
