---
interface Props {
  title: string;
  image: string;
  ctaUrl?: string;
  ctaText?: string;
}

const { title, image, ctaUrl = '/contact', ctaText = 'Contact us →' } = Astro.props;
const isExternal = ctaUrl.startsWith('http');
---

<article class="card">
  <img
    src={image}
    alt={title}
    class="card-image"
    loading="lazy"
    decoding="async"
  />
  <div class="body">
    <h3 class="title">{title}</h3>
    <div class="description">
      <slot />
    </div>
    <a
      href={ctaUrl}
      class="program-cta"
      target={isExternal ? '_blank' : undefined}
      rel={isExternal ? 'noopener noreferrer' : undefined}
    >{ctaText}</a>
  </div>
</article>

<style>
  .card {
    background: #fff;
    border-radius: var(--radius);
    overflow: hidden;
    box-shadow: 0 8px 24px rgba(11, 31, 58, 0.07);
    display: flex;
    flex-direction: column;
  }

  .card-image {
    aspect-ratio: 4 / 3;
    width: 100%;
    object-fit: cover;
    display: block;
  }

  .body {
    padding: 22px 22px 24px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    flex: 1;
  }

  .title {
    font-size: 24px;
    color: var(--navy);
  }

  .description {
    color: var(--muted);
    font-size: 15px;
    line-height: 1.6;
    flex: 1;
  }

  .program-cta {
    color: var(--coral);
    font-weight: 700;
    align-self: flex-start;
    text-decoration: none;
  }

  .program-cta:hover {
    text-decoration: underline;
  }
</style>
