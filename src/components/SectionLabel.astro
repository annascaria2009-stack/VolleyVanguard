---
interface Props {
  text: string;
}

const { text } = Astro.props;
---

<div class="section-label">{text}</div>

<style>
  .section-label {
    color: var(--coral);
    font-size: 12px;
    font-weight: 800;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    margin-bottom: 8px;
  }
</style>
