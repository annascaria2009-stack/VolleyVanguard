---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionLabel from '../components/SectionLabel.astro';
import schedule from '../data/schedule.json';
---
<BaseLayout title="Schedule" description="VolleyVanguard weekly training schedule.">
  <section class="section">
    <div class="wrap">
      <SectionLabel text="Summer Schedule" />
      <h1 class="title">Training Schedule</h1>
      <p class="intro">{schedule.intro}</p>

      <table class="sched">
        <thead>
          <tr>
            <th>Date</th>
            <th>Day</th>
            <th>Time</th>
          </tr>
        </thead>
        <tbody>
          {schedule.rows.map((r) => (
            <tr>
              <td data-label="Date">{r.date}</td>
              <td data-label="Day">{r.day}</td>
              <td data-label="Time">{r.time}</td>
            </tr>
          ))}
        </tbody>
      </table>

      <div class="cta-row">
        <a href="https://forms.gle/J3M7mPKMKhG4AchW6" class="btn" target="_blank" rel="noopener noreferrer">Register now →</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .title {
    font-size:42px;
    color:var(--navy);
    margin-bottom:12px;
  }
  .intro {
    color:var(--muted);
    max-width:640px;
    margin-bottom:32px;
    font-size:17px;
    line-height:1.6;
  }
  .sched {
    width:100%;
    border-collapse:collapse;
    background:#fff;
    border-radius:var(--radius);
    overflow:hidden;
    box-shadow:0 8px 24px rgba(11,31,58,0.07);
  }
  .sched thead { background:var(--navy); color:#fff; }
  .sched th {
    text-align:left;
    padding:14px 16px;
    font-size:12px;
    font-weight:800;
    letter-spacing:1px;
    text-transform:uppercase;
  }
  .sched td {
    padding:16px;
    border-top:1px solid #eef2f8;
    font-size:15px;
    color:var(--ink);
  }
  .sched tbody tr:hover { background:var(--surface); }
  .cta-row {
    margin-top:36px;
    text-align:center;
  }

  /* Mobile: stack as cards */
  @media (max-width: 640px) {
    .sched, .sched tbody, .sched tr, .sched td {
      display:block;
      width:100%;
    }
    .sched thead { display:none; }
    .sched tr {
      background:#fff;
      border-radius:var(--radius);
      box-shadow:0 8px 24px rgba(11,31,58,0.07);
      margin-bottom:14px;
      overflow:hidden;
    }
    .sched td {
      display:flex;
      justify-content:space-between;
      gap:16px;
      padding:12px 16px;
      border-top:1px solid #eef2f8;
    }
    .sched tr td:first-child { border-top:0; }
    .sched td::before {
      content:attr(data-label);
      font-size:11px;
      font-weight:800;
      letter-spacing:1px;
      text-transform:uppercase;
      color:var(--coral);
      align-self:center;
    }
  }
</style>
